{
  "info": {
    "_postman_id": "89953d3b-5a9c-4664-97c3-5ba3c6efc2b1",
    "name": "Helpdesk API — учебная коллекция",
    "description": "Коллекция курса labs/api (модуль 04). Требует environment с переменной base_url (см. local.postman_environment.json). Запросы пронумерованы — Collection Runner выполняет их по порядку: smoke → CRUD-цепочка с передачей ticket_id через переменные → негативные проверки.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 Smoke",
      "item": [
        {
          "name": "Health check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('статус 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('сервис отвечает status=ok', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "10 Tickets CRUD",
      "item": [
        {
          "name": "Список тикетов",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('статус 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('в ответе массив items', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.items).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('есть заголовок X-Total-Count', function () {",
                  "    pm.response.to.have.header('X-Total-Count');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/tickets?per_page=50",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tickets"],
              "query": [
                {"key": "per_page", "value": "50"}
              ]
            }
          },
          "response": []
        },
        {
          "name": "Создать тикет",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('статус 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('есть заголовок Location', function () {",
                  "    pm.response.to.have.header('Location');",
                  "});",
                  "",
                  "pm.test('сервер назначил id и статус open', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.be.a('number');",
                  "    pm.expect(body.status).to.eql('open');",
                  "});",
                  "",
                  "// Передаём id дальше по цепочке: следующие запросы читают {{ticket_id}}",
                  "const body = pm.response.json();",
                  "pm.environment.set('ticket_id', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Создано из Postman\",\n  \"priority\": \"high\",\n  \"requester\": \"postman@corp.example\"\n}",
              "options": {
                "raw": {"language": "json"}
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/tickets",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tickets"]
            }
          },
          "response": []
        },
        {
          "name": "Получить созданный тикет",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('статус 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('это именно созданный тикет', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(String(body.id)).to.eql(pm.environment.get('ticket_id') + '');",
                  "    pm.expect(body.title).to.eql('Создано из Postman');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/tickets/{{ticket_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tickets", "{{ticket_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Взять в работу (PATCH)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('статус 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('статус тикета теперь in_progress', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.status).to.eql('in_progress');",
                  "    pm.expect(body.assignee).to.eql('support');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\",\n  \"assignee\": \"support\"\n}",
              "options": {
                "raw": {"language": "json"}
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/tickets/{{ticket_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tickets", "{{ticket_id}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "20 Негативные проверки",
      "item": [
        {
          "name": "404 — тикет не существует",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('статус 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('код ошибки not_found', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.error.code).to.eql('not_found');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/tickets/999999",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tickets", "999999"]
            }
          },
          "response": []
        },
        {
          "name": "422 — невалидный приоритет",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('статус 422', function () {",
                  "    pm.response.to.have.status(422);",
                  "});",
                  "",
                  "pm.test('в details назван проблемный field=priority', function () {",
                  "    const body = pm.response.json();",
                  "    const fields = body.error.details.map(d => d.field);",
                  "    pm.expect(fields).to.include('priority');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Негативный тест\",\n  \"priority\": \"urgent\"\n}",
              "options": {
                "raw": {"language": "json"}
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/tickets",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tickets"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
